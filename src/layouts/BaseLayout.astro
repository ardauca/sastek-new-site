---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { site } from '../data/site';
import type { Locale } from '../types/content';

interface Props { title: string; description: string; locale?: Locale; image?: string; }
const { title, description, locale = 'tr', image = '/images/backgrounds/space.jpg' } = Astro.props;
const cleanPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const canonical = new URL(cleanPath, site.url).href;
const fullTitle = title.includes('SASTEK') ? title : `${title} | SASTEK`;

const routePairs: Record<string, string> = {
  '/': '/en', '/hakkimizda': '/en/about', '/etkinlikler': '/en/events',
  '/anlasmali-noktalar': '/en/partners', '/sponsorlar': '/en/sponsors',
  '/galeri': '/en/gallery', '/iletisim': '/en/contact',
};

let trPath = cleanPath;
let enPath = routePairs[cleanPath] ?? '/en';
if (cleanPath.startsWith('/en/events/')) { trPath = cleanPath.replace('/en/events/', '/etkinlikler/'); enPath = cleanPath; }
else if (cleanPath.startsWith('/etkinlikler/')) { trPath = cleanPath; enPath = cleanPath.replace('/etkinlikler/', '/en/events/'); }
else if (cleanPath.startsWith('/en')) { enPath = cleanPath; trPath = Object.entries(routePairs).find(([, en]) => en === cleanPath)?.[0] ?? '/'; }

const trUrl = locale === 'tr' ? canonical : new URL(trPath, site.url).href;
const enUrl = locale === 'en' ? canonical : new URL(enPath, site.url).href;
const xDefaultUrl = new URL(trPath, site.url).href;
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#071526" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="tr" href={trUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />
    <link rel="icon" type="image/png" href="/favicon-96x96.png?v=1" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=1" />
    <link rel="shortcut icon" href="/favicon.ico?v=1" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=1" />
    <link rel="manifest" href="/site.webmanifest?v=1" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SASTEK" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, site.url).href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "StudentOrganization",
      "name": "SASTEK",
      "alternateName": locale === 'tr' ? site.fullName.tr : site.fullName.en,
      "url": canonical,
      "logo": new URL("/images/logo/sastek-logo.png", site.url).href,
      "parentOrganization": {
        "@type": "CollegeOrUniversity",
        "name": locale === 'tr' ? site.institution.tr : site.institution.en
      },
      "sameAs": [
        "https://www.instagram.com/esastek/",
        "https://www.linkedin.com/company/savunma-sanayii-ve-teknolojileri-kul%C3%BCb%C3%BC/",
        "https://x.com/esastek",
        "https://www.youtube.com/channel/UCFzo4lHVQfCmF-lChl7Xbgw"
      ]
    })} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <a class="skip" href="#content">{locale === 'tr' ? 'İçeriğe geç' : 'Skip to content'}</a>
    <Header locale={locale} currentPath={cleanPath} />
    <main id="content"><slot /></main>
    <Footer locale={locale} />
  </body>
</html>
<style>
  .skip { position: fixed; left: 1rem; top: -5rem; z-index: 100; border-radius: .4rem; background: #fff; color: #07111f; padding: .6rem 1rem; font-weight: 800; }
  .skip:focus { top: 1rem; }
</style>
