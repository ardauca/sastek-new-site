---
import { formatDate, t } from '../../lib/content';
import type { EventItem, Locale } from '../../types/content';

interface Props { event: EventItem; locale: Locale; }

const { event, locale } = Astro.props;
const href = locale === 'tr' ? `/etkinlikler/${event.slug}` : `/en/events/${event.slug}`;
const showDetails = event.showDetails !== false;
const status = {
  planned: { tr: 'Planlanıyor', en: 'Planned' },
  active: { tr: 'Aktif', en: 'Active' },
  past: { tr: 'Geçmiş', en: 'Past' },
}[event.status][locale];
---

<article class="event-card glass" data-filter-card data-category={t(event.category, locale).toLowerCase()} data-search={`${t(event.title, locale)} ${t(event.summary, locale)}`.toLowerCase()}>
  <a href={href} class="visual" aria-label={t(event.title, locale)}>
    <img src={event.image} alt="" width="600" height="360" loading="lazy" />
  </a>
  <div class="body">
    <div class="meta">
      <span class="chip">{t(event.category, locale)}</span>
      {showDetails && <span class="status">{status}</span>}
    </div>
    <h3><a href={href}>{t(event.title, locale)}</a></h3>
    <p class="muted">{t(event.summary, locale)}</p>
    <div class="foot">
      {showDetails && <span>{formatDate(event.date, locale)}</span>}
      <a class="read-more" href={href}>{locale === 'tr' ? 'İncele' : 'Explore'} <span aria-hidden="true">→</span></a>
    </div>
  </div>
</article>

<style>
  .event-card{position:relative;overflow:hidden;border-radius:1.25rem;transition:border-color .2s,transform .2s,background .2s,box-shadow .2s}
  .event-card::after{content:"";position:absolute;right:-4.5rem;bottom:-5rem;width:13rem;aspect-ratio:1;border-radius:50%;background:radial-gradient(circle,rgba(255,107,26,.1),transparent 66%);pointer-events:none}
  .event-card:hover{border-color:rgba(255,107,26,.34);background:linear-gradient(145deg,rgba(16,43,70,.74),rgba(7,21,38,.82));box-shadow:0 22px 60px rgba(0,0,0,.18);transform:translateY(-3px)}
  .visual{position:relative;display:grid;place-items:center;min-height:205px;overflow:hidden;background:radial-gradient(circle at 50% 35%,rgba(31,74,112,.52),rgba(6,18,32,.96) 68%)}
  .visual::before{content:"";position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.08),transparent 34%,rgba(255,107,26,.08));opacity:.72}
  .visual::after{content:"";position:absolute;left:1rem;right:1rem;bottom:0;height:1px;background:linear-gradient(90deg,transparent,rgba(128,174,213,.32),transparent)}
  .visual img{position:relative;z-index:1;width:78%;height:158px;object-fit:contain;filter:drop-shadow(0 18px 26px rgba(0,0,0,.32));transition:transform .25s,filter .25s}
  .event-card:hover .visual img{transform:scale(1.035);filter:drop-shadow(0 22px 32px rgba(0,0,0,.38))}
  .body{position:relative;z-index:1;display:grid;padding:1.25rem 1.25rem 1.15rem}
  .meta,.foot{display:flex;align-items:center;justify-content:space-between;gap:1rem}
  .meta{min-height:2rem;font-size:.75rem;color:#8fa6bb}
  .chip{border-color:rgba(128,174,213,.28);background:rgba(128,174,213,.08);color:#dce9f5}
  .status{color:#9fb2c5;font-weight:800}
  .body h3{margin:.95rem 0 .4rem;font-size:clamp(1.25rem,2vw,1.5rem);line-height:1.12;letter-spacing:-.035em}
  .body h3 a{color:#fff}
  .body h3 a:hover{color:#ffb184}
  .body p{margin:0;min-height:3.6rem;color:#b5c5d5;line-height:1.65}
  .foot{margin-top:1.15rem;padding-top:1rem;border-top:1px solid rgba(84,119,151,.18);font-size:.78rem;color:#8fa6bb}
  .read-more{display:inline-flex;align-items:center;gap:.35rem;margin-left:auto;color:#ff9a62;font-weight:900}
  .read-more span{transition:transform .2s}
  .read-more:hover{color:#fff}
  .read-more:hover span{transform:translateX(3px)}
  @media(max-width:560px){.visual{min-height:180px}.visual img{height:138px}.body{padding:1.05rem}.body p{min-height:auto}.foot{align-items:flex-start;flex-direction:column}.read-more{margin-left:0}}
</style>
