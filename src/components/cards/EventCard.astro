---
import { formatDate, t } from '../../lib/content';
import type { EventItem, Locale } from '../../types/content';
interface Props { event: EventItem; locale: Locale; }
const { event, locale } = Astro.props;
const href = locale === 'tr' ? `/etkinlikler/${event.slug}` : `/en/events/${event.slug}`;
const showDetails = event.showDetails !== false;
const status = { planned: { tr: 'Planlanıyor', en: 'Planned' }, active: { tr: 'Aktif', en: 'Active' }, past: { tr: 'Geçmiş', en: 'Past' } }[event.status][locale];
---
<article class="event-card glass" data-filter-card data-category={t(event.category, locale).toLowerCase()} data-search={`${t(event.title, locale)} ${t(event.summary, locale)}`.toLowerCase()}>
  <a href={href} class="visual" aria-label={t(event.title, locale)}><img src={event.image} alt="" width="600" height="360" loading="lazy" /></a>
  <div class="body">
    <div class="meta"><span class="chip">{t(event.category, locale)}</span>{showDetails && <span>{status}</span>}</div>
    <h3><a href={href}>{t(event.title, locale)}</a></h3>
    <p class="muted">{t(event.summary, locale)}</p>
    <div class="foot">{showDetails && <span>{formatDate(event.date, locale)}</span>}<a href={href}>{locale === 'tr' ? 'İncele →' : 'Explore →'}</a></div>
  </div>
</article>
<style>
  .event-card{overflow:hidden;border-radius:1.25rem}.visual{display:grid;place-items:center;min-height:190px;background:#f6f7f8}.visual img{width:80%;height:150px;object-fit:contain}.body{padding:1.25rem}.meta,.foot{display:flex;align-items:center;justify-content:space-between;gap:1rem;font-size:.75rem;color:#8fa6bb}.body h3{margin:.9rem 0 .35rem;font-size:1.35rem;line-height:1.2}.body p{margin:0;min-height:3.4rem}.foot{margin-top:1.2rem;padding-top:1rem;border-top:1px solid rgba(84,119,151,.2)}.foot a{color:#ff9a62;font-weight:800}
</style>
