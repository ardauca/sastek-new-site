---
import { navigation } from '../../data/navigation';
import { site } from '../../data/site';
import { socials } from '../../data/socials';
import { t } from '../../lib/content';
import type { Locale } from '../../types/content';
import SocialIcon from '../ui/SocialIcon.astro';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const activeSocials = socials
  .filter((item) => item.isActive && item.url && item.url !== '#')
  .sort((a, b) => a.order - b.order);
---
<footer>
  <div class="container footer-grid">
    <div>
      <div class="footer-brand">SASTEK<span>.</span></div>
      <p class="muted">{t(site.fullName, locale)}<br />{t(site.institution, locale)}</p>
    </div>
    <nav aria-label={locale === 'tr' ? 'Alt menü' : 'Footer menu'}>
      {navigation.slice(1).map((item) => <a href={item[locale]}>{t(item.label, locale)}</a>)}
    </nav>
    <div>
      <p class="eyebrow">{locale === 'tr' ? 'Bağlantıda kal' : 'Stay connected'}</p>
      {activeSocials.length > 0 ? <div class="socials">{activeSocials.map((item) => <a href={item.url} rel="noreferrer" target="_blank" aria-label={`${item.label} ${locale === 'tr' ? 'sayfasını yeni sekmede aç' : 'opens in a new tab'}`}><SocialIcon icon={item.icon} /><span>{item.icon === 'x' ? 'Twitter/X' : item.label}</span></a>)}</div> : <p class="muted small">{locale === 'tr' ? 'Sosyal medya bağlantıları güncellenecek.' : 'Social links will be updated.'}</p>}
    </div>
  </div>
  <div class="container copyright">
    <p class="text-sm text-white/50">
      &copy; 2026 SASTEK. Tüm hakları saklıdır. | Developed by <a href="https://github.com/ardauca" target="_blank" rel="noopener noreferrer" class="text-white/70 hover:text-[#ff6b1a] transition-colors underline underline-offset-4">Arda Uça</a>
    </p>
  </div>
</footer>
<style>
  footer { border-top: 1px solid rgba(84,119,151,.22); padding: 4rem 0 1.5rem; background: rgba(3,8,15,.7); }
  .footer-grid { display: grid; grid-template-columns: 1.3fr 1fr 1fr; gap: 3rem; }
  .footer-brand { font-size: 1.6rem; font-weight: 950; letter-spacing: -.04em; }.footer-brand span { color: #ff6b1a; }
  nav { display: grid; grid-template-columns: 1fr 1fr; gap: .5rem 1rem; } nav a { color: #a9bbce; font-size: .9rem; } nav a:hover { color: #fff; }
  .socials { display: flex; gap: .7rem; flex-wrap: wrap; }
  .socials a { display: inline-flex; align-items: center; gap: .48rem; min-height: 2.9rem; padding: .78rem 1.05rem; border: 1px solid rgba(84,119,151,.75); border-radius: 999px; color: #fff; font-weight: 850; line-height: 1; background: rgba(7,22,38,.35); }
  .socials a:hover { border-color: rgba(255,107,26,.75); color: #fff; background: rgba(255,107,26,.08); transform: translateY(-1px); }
  .socials :global(.social-icon) { width: 1rem; height: 1rem; fill: currentColor; flex: 0 0 auto; }
  .small{font-size:.9rem}.copyright { margin-top: 3rem; padding-top: 1.2rem; border-top: 1px solid rgba(84,119,151,.18); color: #72889d; font-size: .78rem; }
  @media(max-width:760px){.footer-grid{grid-template-columns:1fr}.footer-grid nav{grid-template-columns:1fr 1fr}}
</style>
