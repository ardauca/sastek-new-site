---
interface Props { eyebrow: string; title: string; text: string; }
const { eyebrow, title, text } = Astro.props;
---
<section class="page-hero">
  <div class="container">
    <p class="eyebrow">{eyebrow}</p>
    <h1 class="title">{title}</h1>
    <p class="muted">{text}</p>
  </div>
</section>
<style>
  .page-hero { padding: clamp(5rem, 10vw, 8rem) 0 3.5rem; border-bottom: 1px solid rgba(84,119,151,.16); }.page-hero .container{max-width:900px;text-align:center}.page-hero .title{font-size:clamp(2.7rem,7vw,5.6rem)}.page-hero .muted{max-width:700px;margin:1rem auto 0;font-size:1.1rem}
</style>
