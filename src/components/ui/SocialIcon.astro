---
import type { SocialLink } from '../../types/content';

interface Props {
  icon: SocialLink['icon'];
}

const { icon } = Astro.props;
---

{
  icon === 'instagram' && (
    <svg aria-hidden="true" viewBox="0 0 24 24" class="social-icon">
      <path d="M7.75 2h8.5A5.76 5.76 0 0 1 22 7.75v8.5A5.76 5.76 0 0 1 16.25 22h-8.5A5.76 5.76 0 0 1 2 16.25v-8.5A5.76 5.76 0 0 1 7.75 2Zm0 2A3.75 3.75 0 0 0 4 7.75v8.5A3.75 3.75 0 0 0 7.75 20h8.5A3.75 3.75 0 0 0 20 16.25v-8.5A3.75 3.75 0 0 0 16.25 4h-8.5ZM12 7.1a4.9 4.9 0 1 1 0 9.8 4.9 4.9 0 0 1 0-9.8Zm0 2a2.9 2.9 0 1 0 0 5.8 2.9 2.9 0 0 0 0-5.8Zm5.15-2.35a1.15 1.15 0 1 1 0 2.3 1.15 1.15 0 0 1 0-2.3Z" />
    </svg>
  )
}
{
  icon === 'linkedin' && (
    <svg aria-hidden="true" viewBox="0 0 24 24" class="social-icon">
      <path d="M4.98 3.5a2.48 2.48 0 1 1 0 4.96 2.48 2.48 0 0 1 0-4.96ZM3 9.25h3.96V21H3V9.25Zm6.25 0h3.79v1.6h.05c.53-1 1.82-2.05 3.75-2.05 4.01 0 4.75 2.64 4.75 6.07V21h-3.95v-5.44c0-1.3-.02-2.97-1.81-2.97-1.82 0-2.1 1.42-2.1 2.88V21H9.25V9.25Z" />
    </svg>
  )
}
{
  icon === 'youtube' && (
    <svg aria-hidden="true" viewBox="0 0 24 24" class="social-icon">
      <path d="M23.5 6.2a3 3 0 0 0-2.1-2.13C19.55 3.57 12 3.57 12 3.57s-7.55 0-9.4.5A3 3 0 0 0 .5 6.2 31.1 31.1 0 0 0 0 12a31.1 31.1 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.13c1.85.5 9.4.5 9.4.5s7.55 0 9.4-.5a3 3 0 0 0 2.1-2.13A31.1 31.1 0 0 0 24 12a31.1 31.1 0 0 0-.5-5.8ZM9.6 15.57V8.43L15.86 12 9.6 15.57Z" />
    </svg>
  )
}
{
  icon === 'x' && (
    <svg aria-hidden="true" viewBox="0 0 24 24" class="social-icon">
      <path d="M18.9 2.25h3.68l-8.04 9.19L24 21.75h-7.41l-5.8-7.58-6.64 7.58H.47l8.6-9.83L0 2.25h7.59l5.24 6.92 6.07-6.92Zm-1.29 17.68h2.04L6.48 3.97H4.29l13.32 15.96Z" />
    </svg>
  )
}

<style>
  .social-icon {
    display: block;
    width: 1rem;
    height: 1rem;
    fill: currentColor;
    flex: 0 0 auto;
  }
</style>
