---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../ui/PageHero.astro';
import FilterControls from '../ui/FilterControls.astro';
import { gallery } from '../../data/gallery';
import { t } from '../../lib/content';
import type { Locale } from '../../types/content';
interface Props { locale: Locale; }
const { locale }=Astro.props;
const sorted=[...gallery].sort((a,b)=>a.order-b.order);
const categories=[...new Set(sorted.map((item)=>t(item.category,locale)))];
const title=locale==='tr'?'Galeri':'Gallery';
const desc=locale==='tr'?'Etkinliklerden, teknik buluşmalardan ve kulüp yaşamından seçilmiş anlar.':'Selected moments from events, technical meetups and club life.';
---
<BaseLayout title={title} description={desc} locale={locale}>
  <PageHero eyebrow="SASTEK / GALLERY" title={title} text={desc} />
  <section class="section"><div class="container" data-filter-root><FilterControls locale={locale} categories={categories} showSearch={false} /><div class="gallery-grid">{sorted.map((item,index)=><button data-filter-card data-category={t(item.category,locale).toLowerCase()} data-search={t(item.alt,locale).toLowerCase()} data-lightbox-src={item.src} data-lightbox-alt={t(item.alt,locale)} aria-label={`${locale==='tr'?'Görseli büyüt':'Enlarge image'}: ${t(item.alt,locale)}`}><img src={item.src} alt={t(item.alt,locale)} width="720" height="520" loading={index>1?'lazy':'eager'} /><span>{t(item.category,locale)}</span></button>)}</div></div></section>
  <dialog id="lightbox" aria-label={locale==='tr'?'Galeri görseli':'Gallery image'}><button class="close" aria-label={locale==='tr'?'Kapat':'Close'}>×</button><img src="" alt="" /></dialog>
</BaseLayout>
<script>
  const dialog=document.querySelector<HTMLDialogElement>('#lightbox'); const image=dialog?.querySelector<HTMLImageElement>('img');
  document.querySelectorAll<HTMLButtonElement>('[data-lightbox-src]').forEach((button)=>button.addEventListener('click',()=>{if(image&&dialog){image.src=button.dataset.lightboxSrc??'';image.alt=button.dataset.lightboxAlt??'';dialog.showModal();}}));
  dialog?.querySelector('.close')?.addEventListener('click',()=>dialog.close());
  dialog?.addEventListener('click',(event)=>{if(event.target===dialog)dialog.close();});
</script>
<style>.gallery-grid{display:grid;grid-template-columns:repeat(12,1fr);grid-auto-rows:260px;gap:1rem}.gallery-grid button{position:relative;grid-column:span 5;overflow:hidden;border:1px solid rgba(84,119,151,.25);border-radius:1rem;background:#071526;padding:0;cursor:zoom-in}.gallery-grid button:nth-child(3n+1){grid-column:span 7}.gallery-grid img{width:100%;height:100%;object-fit:cover;transition:transform .35s}.gallery-grid button:hover img{transform:scale(1.03)}.gallery-grid span{position:absolute;left:.8rem;bottom:.8rem;border-radius:999px;background:rgba(5,11,20,.8);padding:.3rem .7rem;font-size:.72rem;font-weight:800}dialog{width:min(1100px,calc(100% - 2rem));height:min(780px,calc(100% - 2rem));border:1px solid #395674;border-radius:1rem;background:#03070d;padding:1rem}dialog::backdrop{background:rgba(0,0,0,.85);backdrop-filter:blur(6px)}dialog img{width:100%;height:100%;object-fit:contain}.close{position:absolute;right:1rem;top:1rem;z-index:2;width:2.5rem;height:2.5rem;border:0;border-radius:50%;background:#ff6b1a;color:#07111f;font-size:1.7rem;cursor:pointer}@media(max-width:700px){.gallery-grid{display:grid;grid-template-columns:1fr;grid-auto-rows:230px}.gallery-grid button,.gallery-grid button:nth-child(3n+1){grid-column:auto}}</style>
