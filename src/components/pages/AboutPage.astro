---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../ui/PageHero.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import type { Locale } from '../../types/content';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const c = locale === 'tr' ? {
  title:'Hakkımızda',desc:'SASTEK’in kuruluşunu, amacını ve birlikte ürettiğimiz kulüp kültürünü keşfedin.',intro:'Teknik merakı gerçek deneyime dönüştüren öğrenci topluluğu.',
  body:'Savunma Sanayii ve Teknolojileri Kulübü (SASTEK), Eskişehir Teknik Üniversitesi bünyesinde öğrenim gören farklı mühendislik disiplinlerinden öğrenciler tarafından 2019 yılının güz döneminde kuruldu.',
  mission:'Amacımız',missionText:'Öğrencileri savunma sanayii, havacılık, uzay, mühendislik, teknoloji, Ar-Ge ve kariyer alanlarında bir araya getirmek; öğrenme, paylaşma ve sektörle temas fırsatları oluşturmaktır.',
  culture:'Kulüp kültürümüz',cultureText:'Merak etmeyi, sorumluluk almayı ve ekip olarak üretmeyi önemsiyoruz. Teknik gelişimin güçlü bir topluluk içinde daha anlamlı olduğuna inanıyoruz.'
} : {
  title:'About',desc:'Discover SASTEK’s foundation, purpose and the club culture we build together.',intro:'A student community turning technical curiosity into real experience.',
  body:'The Defence Industry and Technologies Club (SASTEK) was founded in autumn 2019 by students from different engineering disciplines at Eskişehir Technical University.',
  mission:'Our purpose',missionText:'We bring students together across defence, aviation, space, engineering, technology, R&D and careers, creating opportunities to learn, share and engage with industry.',
  culture:'Our culture',cultureText:'We value curiosity, ownership and creating as a team. We believe technical growth becomes more meaningful within a strong community.'
};
---
<BaseLayout title={c.title} description={c.desc} locale={locale}>
  <PageHero eyebrow="SASTEK / ABOUT" title={c.title} text={c.desc} />
  <section class="section"><div class="container split"><div><SectionHeading title={c.intro} text={c.body} /></div><div class="year glass"><strong>2019</strong><span>{locale==='tr'?'Eskişehir’de kuruldu':'Founded in Eskişehir'}</span></div></div></section>
  <section class="section dark"><div class="container two"><div class="glass card"><span>01</span><h2>{c.mission}</h2><p class="muted">{c.missionText}</p></div><div class="glass card"><span>02</span><h2>{c.culture}</h2><p class="muted">{c.cultureText}</p></div></div></section>
</BaseLayout>
<style>.split{display:grid;grid-template-columns:1.3fr .7fr;gap:5rem;align-items:center}.year{min-height:270px;border-radius:50%;aspect-ratio:1;display:grid;place-content:center;text-align:center}.year strong{color:#ff6b1a;font-size:4.5rem;line-height:1}.year span{margin-top:.7rem;color:#a9bbce}.dark{background:rgba(5,14,25,.55)}.two{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem}.card{border-radius:1.2rem;padding:2rem}.card>span{color:#ff6b1a;font:700 .75rem monospace}.card h2{font-size:1.7rem}@media(max-width:760px){.split,.two{grid-template-columns:1fr}.year{width:min(100%,260px);margin:auto}}</style>
