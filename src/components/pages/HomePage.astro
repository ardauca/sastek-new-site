---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import EventCard from '../cards/EventCard.astro';
import PartnerCard from '../cards/PartnerCard.astro';
import RadarHud from '../ui/RadarHud.astro';
import { events } from '../../data/events';
import { partners } from '../../data/partners';
import { sponsors } from '../../data/sponsors';
import { gallery } from '../../data/gallery';
import { site } from '../../data/site';
import { t } from '../../lib/content';
import type { Locale } from '../../types/content';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const featuredEvents = events.filter((item) => item.isFeatured).slice(0, 3);
const featuredPartners = partners.filter((item) => item.isActive && item.isFeatured).sort((a,b) => a.order-b.order).slice(0, 3);
const featuredSponsors = sponsors.filter((item) => item.isActive && item.isFeatured).sort((a,b) => a.order-b.order);
const featuredGallery = gallery.filter((item) => item.isFeatured).sort((a,b) => a.order-b.order).slice(0, 3);
const path = (tr: string, en: string) => locale === 'tr' ? tr : `/en${en}`;
const copy = locale === 'tr' ? {
  badge: 'Eskişehir Teknik Üniversitesi · 2019’dan beri', titleA: 'Kampüsten', titleB: 'Savunma', titleC: 'Sanayiine.',
  hero: site.description.tr, events: 'Etkinlikleri Gör', contact: 'Bize Ulaş',
  aboutEyebrow: 'Biz kimiz?', aboutTitle: 'Merakı, mühendisliği ve sektörü aynı yörüngede buluşturuyoruz.',
  aboutText: '2019 yılında farklı mühendislik disiplinlerinden öğrenciler tarafından kurulan SASTEK; savunma sanayii, havacılık, uzay, Ar-Ge ve kariyer alanlarında öğrenciler için güçlü bir öğrenme ve paylaşım ağı oluşturur.',
  eventTitle: 'Fikrin deneyime dönüştüğü etkinlikler', eventText: 'Sektör buluşmalarından teknik gezilere, eğitimlerden sosyal etkinliklere uzanan dinamik bir program.',
  partnerTitle: 'Öğrenci hayatına değer katan anlaşmalar', partnerText: 'SASTEK üyeleri için özel indirim ve ayrıcalıklar sunan iş ortaklarımız.',
  sponsorTitle: 'Birlikte daha ileri', sponsorText: 'SASTEK’in öğrenci odaklı çalışmalarına destek veren kurumlar.',
  galleryTitle: 'SASTEK’ten kareler', galleryText: 'Teknik merakın, ekip ruhunun ve yeni bağlantıların bir araya geldiği anlar.',
  cta: 'Aynı geleceğe bakıyorsak tanışalım.', ctaText: 'SASTEK’in etkinlikleri, projeleri ve iş birlikleri hakkında bizimle iletişime geçin.', all: 'Tümünü gör',
} : {
  badge: 'Eskişehir Technical University · Since 2019', titleA: 'From Campus to', titleB: 'Defence', titleC: 'Industry.',
  hero: site.description.en, events: 'Explore Events', contact: 'Contact Us',
  aboutEyebrow: 'Who we are', aboutTitle: 'Bringing curiosity, engineering and industry into the same orbit.',
  aboutText: 'Founded in 2019 by students from different engineering disciplines, SASTEK builds a strong learning and sharing network across defence, aviation, space, R&D and careers.',
  eventTitle: 'Where ideas turn into experience', eventText: 'A dynamic programme ranging from industry meetups and technical visits to training and social events.',
  partnerTitle: 'Benefits for student life', partnerText: 'Our partner venues offering exclusive discounts and perks for SASTEK members.',
  sponsorTitle: 'Further, together', sponsorText: 'Organisations supporting SASTEK’s student-centred work.',
  galleryTitle: 'Life at SASTEK', galleryText: 'Moments where technical curiosity, team spirit and new connections come together.',
  cta: 'Looking toward the same future?', ctaText: 'Get in touch about SASTEK events, projects and collaborations.', all: 'View all',
};
const pageTitle = locale === 'tr'
  ? 'SASTEK | Eskişehir Teknik Üniversitesi Savunma Sanayii ve Teknolojileri Kulübü'
  : 'SASTEK | Eskişehir Technical University Defence Industry & Technology Club';
---
<BaseLayout title={pageTitle} description={copy.hero} locale={locale}>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">{copy.badge}</p>
        <h1 class="display">{copy.titleA}<br /><span>{copy.titleB}</span><br />{copy.titleC}</h1>
        <p class="lead muted">{copy.hero}</p>
        <div class="actions"><a class="btn btn-primary" href={path('/etkinlikler','/events')}>{copy.events} <span>↗</span></a><a class="btn btn-secondary" href={path('/iletisim','/contact')}>{copy.contact}</a></div>
      </div>
      <div class="hero-visual">
        <RadarHud />
      </div>
    </div>
  </section>

  <section class="section about"><div class="container about-grid"><div><SectionHeading eyebrow={copy.aboutEyebrow} title={copy.aboutTitle} text={copy.aboutText} /><a class="btn btn-secondary" href={path('/hakkimizda','/about')}>{copy.all} →</a></div><div class="pillars"><div><span>01</span><b>{locale==='tr'?'Savunma Sanayii':'Defence Industry'}</b></div><div><span>02</span><b>{locale==='tr'?'Havacılık & Uzay':'Aviation & Space'}</b></div><div><span>03</span><b>{locale==='tr'?'Mühendislik':'Engineering'}</b></div><div><span>04</span><b>Ar-Ge · R&D</b></div></div></div></section>

  <section class="section"><div class="container"><SectionHeading eyebrow="SASTEK / EVENTS" title={copy.eventTitle} text={copy.eventText} /><div class="grid-auto">{featuredEvents.map((event) => <EventCard event={event} locale={locale} />)}</div><div class="section-link"><a class="btn btn-secondary" href={path('/etkinlikler','/events')}>{copy.all} →</a></div></div></section>

  <section class="section band"><div class="container"><SectionHeading eyebrow="SASTEK / PARTNERS" title={copy.partnerTitle} text={copy.partnerText} /><div class="grid-auto">{featuredPartners.map((partner) => <PartnerCard partner={partner} locale={locale} />)}</div><div class="section-link"><a class="btn btn-secondary" href={path('/anlasmali-noktalar','/partners')}>{copy.all} →</a></div></div></section>

  <section class="section"><div class="container sponsor-row"><SectionHeading eyebrow="SASTEK / SUPPORT" title={copy.sponsorTitle} text={copy.sponsorText} /><div class="sponsor-list">{featuredSponsors.map((sponsor) => <div class="sponsor glass"><img src={sponsor.logo} alt={`${sponsor.name} logo`} loading="lazy" /><span>{locale==='tr'?'Doğrulama bekliyor':'Awaiting verification'}</span></div>)}</div></div></section>

  <section class="section"><div class="container"><SectionHeading eyebrow="SASTEK / GALLERY" title={copy.galleryTitle} text={copy.galleryText} /><div class="gallery-preview">{featuredGallery.map((item, index) => <img class={`g${index+1}`} src={item.src} alt={t(item.alt, locale)} width="720" height="520" loading="lazy" />)}</div><div class="section-link"><a class="btn btn-secondary" href={path('/galeri','/gallery')}>{copy.all} →</a></div></div></section>

  <section class="section"><div class="container cta glass"><div><p class="eyebrow">SASTEK / CONTACT</p><h2 class="title">{copy.cta}</h2><p class="muted">{copy.ctaText}</p></div><a class="btn btn-primary" href={path('/iletisim','/contact')}>{copy.contact} →</a></div></section>
</BaseLayout>
<style>
  .hero{position:relative;min-height:calc(100svh - 4.75rem);display:grid;align-items:center;overflow:hidden;padding:clamp(4rem,7vw,6.2rem) 0 clamp(3rem,6vw,5.2rem)}
  .hero::before{content:"";position:absolute;inset:8% auto 10% -12%;width:min(760px,72vw);border-radius:50%;background:radial-gradient(ellipse at center,rgba(7,21,38,.78),rgba(7,21,38,.38) 52%,transparent 72%);pointer-events:none}
  .hero-grid{position:relative;display:grid;grid-template-columns:minmax(0,1.04fr) minmax(360px,.96fr);align-items:center;gap:clamp(2.4rem,5vw,4.6rem)}
  .hero-copy{position:relative;z-index:1;max-width:760px}
  .hero .eyebrow{color:#ff8a49}
  .display{max-width:820px;margin:.8rem 0 1.25rem;font-size:clamp(3.25rem,8.1vw,7.35rem);line-height:.88;letter-spacing:-.075em;text-wrap:balance}
  .display span{color:#ff7a2f;text-shadow:0 0 22px rgba(255,107,26,.12)}
  .lead{max-width:610px;color:#bdcad8;font-size:clamp(1rem,1.5vw,1.16rem);line-height:1.75}
  .actions{display:flex;align-items:center;gap:.85rem;flex-wrap:wrap;margin-top:2.15rem}
  .actions .btn{min-height:3.15rem;padding-inline:1.2rem}
  .actions .btn-primary{box-shadow:0 16px 38px rgba(255,107,26,.18)}
  .actions .btn-secondary{background:rgba(7,21,38,.28)}
  .hero-visual{position:relative;min-height:520px;display:grid;place-items:center}

  .about{background:linear-gradient(90deg,rgba(8,24,41,.72),rgba(8,24,41,.2))}
  .about-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:5rem;align-items:center}
  .pillars{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
  .pillars div{min-height:140px;border:1px solid rgba(84,119,151,.28);border-radius:1rem;padding:1.2rem;background:rgba(7,21,38,.55)}
  .pillars span{display:block;color:#ff6b1a;font:700 .75rem monospace}
  .pillars b{display:block;margin-top:2.4rem}
  .section-link{display:flex;justify-content:center;margin-top:2rem}
  .band{background:rgba(6,17,30,.56);border-block:1px solid rgba(84,119,151,.16)}
  .sponsor-row{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
  .sponsor-list{display:grid;gap:1rem}
  .sponsor{min-height:170px;border-radius:1.2rem;display:grid;place-items:center;padding:1rem}
  .sponsor img{max-width:260px;max-height:100px;object-fit:contain;filter:grayscale(1) brightness(1.5)}
  .sponsor span{font-size:.72rem;color:#ff9a62}
  .gallery-preview{display:grid;grid-template-columns:1.2fr .8fr;grid-template-rows:230px 230px;gap:1rem}
  .gallery-preview img{width:100%;height:100%;object-fit:cover;border-radius:1rem;border:1px solid rgba(84,119,151,.24)}
  .gallery-preview .g1{grid-row:1/3}
  .cta{display:flex;align-items:center;justify-content:space-between;gap:2rem;border-radius:1.5rem;padding:clamp(1.5rem,5vw,3.5rem)}
  .cta p{max-width:650px}.cta .muted{margin-bottom:0}
  @media(max-width:900px){.hero{padding-top:3.4rem}.hero-grid,.about-grid,.sponsor-row{grid-template-columns:1fr}.hero-copy{max-width:720px}.hero-visual{min-height:360px;order:2}.about-grid{gap:2.5rem}}
  @media(max-width:650px){.hero{min-height:auto;padding:3.2rem 0 3.6rem}.display{font-size:clamp(3rem,16vw,4.7rem);line-height:.92;letter-spacing:-.065em}.lead{font-size:1rem;line-height:1.7}.actions{display:grid;grid-template-columns:1fr;gap:.7rem;margin-top:1.7rem}.actions .btn{justify-content:center;width:100%}.hero-visual{display:grid;min-height:300px;margin-top:.4rem}.pillars{grid-template-columns:1fr 1fr}.pillars div{min-height:110px}.pillars b{margin-top:1.5rem}.gallery-preview{grid-template-columns:1fr;grid-template-rows:240px 180px 180px}.gallery-preview .g1{grid-row:auto}.cta{align-items:flex-start;flex-direction:column}}
  /* ── Large Desktop Scale (1600px+) ── */
  @media(min-width:1600px){.hero-grid{gap:5.5rem}.display{font-size:9rem}.lead{font-size:1.28rem}}
</style>
