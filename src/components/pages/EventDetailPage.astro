---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate, t } from '../../lib/content';
import type { EventItem, Locale } from '../../types/content';
interface Props { locale: Locale; event: EventItem; }
const { locale, event } = Astro.props;
const title=t(event.title,locale); const back=locale==='tr'?'/etkinlikler':'/en/events';
const showDetails = event.showDetails !== false;
const statusLabels: Record<EventItem['status'], Record<Locale, string>> = {
  planned: { tr: 'Planlanıyor', en: 'Planned' },
  active: { tr: 'Aktif', en: 'Active' },
  past: { tr: 'Tamamlandı', en: 'Completed' },
};
---
<BaseLayout title={title} description={t(event.summary,locale)} locale={locale} image={event.image}>
  <article>
    <header class="detail-head"><div class="container"><a class="back" href={back}>← {locale==='tr'?'Tüm etkinlikler':'All events'}</a><div class="detail-grid"><div><span class="chip">{t(event.category,locale)}</span><h1 class="title">{title}</h1><p class="muted lead">{t(event.summary,locale)}</p></div><div class="visual glass"><img src={event.image} alt="" width="700" height="460" /></div></div></div></header>
    <section class="section"><div class={`container content-grid ${!showDetails ? 'no-details' : ''}`}><div><p class="eyebrow">{locale==='tr'?'Etkinlik hakkında':'About the event'}</p><p class="body">{t(event.description,locale)}</p>{event.applicationUrl&&<a class="btn btn-primary" href={event.applicationUrl}>{locale==='tr'?'Başvuru bağlantısı':'Application link'} ↗</a>}</div>{showDetails && <aside class="glass"><div><span>{locale==='tr'?'Tarih':'Date'}</span><b>{formatDate(event.date,locale)}</b></div><div><span>{locale==='tr'?'Konum':'Location'}</span><b>{t(event.location,locale)}</b></div><div><span>{locale==='tr'?'Durum':'Status'}</span><b>{statusLabels[event.status][locale]}</b></div></aside>}</div></section>
  </article>
</BaseLayout>
<style>.detail-head{padding:4rem 0;border-bottom:1px solid rgba(84,119,151,.16)}.back{display:inline-block;margin-bottom:2rem;color:#ff9a62;font-weight:800}.detail-grid{display:grid;grid-template-columns:1fr .8fr;gap:4rem;align-items:center}.detail-grid h1{margin:.8rem 0}.lead{font-size:1.1rem}.visual{display:grid;place-items:center;min-height:320px;border-radius:1.3rem;background:#f4f5f5}.visual img{width:80%;height:240px;object-fit:contain}.content-grid{display:grid;grid-template-columns:1.2fr .8fr;gap:5rem}.content-grid.no-details{grid-template-columns:minmax(0,760px)}.body{font-size:1.2rem;color:#d3e0ec;max-width:720px}.content-grid aside{border-radius:1rem;padding:1.5rem}.content-grid aside div{display:grid;gap:.25rem;padding:1rem 0;border-bottom:1px solid rgba(84,119,151,.18)}.content-grid aside div:last-child{border:0}.content-grid aside span{color:#8fa6bb;font-size:.75rem;text-transform:uppercase;letter-spacing:.12em}@media(max-width:760px){.detail-grid,.content-grid{grid-template-columns:1fr;gap:2rem}}</style>
