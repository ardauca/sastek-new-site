---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../ui/PageHero.astro';
import { socials } from '../../data/socials';
import { team } from '../../data/team';
import type { Locale } from '../../types/content';
import SocialIcon from '../ui/SocialIcon.astro';

interface Props { locale: Locale; }

const { locale }=Astro.props;
const activeSocials=socials.filter((s)=>s.isActive&&s.url&&s.url!=='#').sort((a,b)=>a.order-b.order);
const activeTeam=team.filter((p)=>p.isActive).sort((a,b)=>a.order-b.order).slice(0,3);
const title=locale==='tr'?'İletişim':'Contact';
const desc=locale==='tr'?'SASTEK yönetimi ve sosyal medya hesaplarıyla iletişim kurun.':'Contact the SASTEK board and follow our social media accounts.';

const initials=(name:string)=>name
  .split(' ')
  .filter(Boolean)
  .slice(0,2)
  .map((part)=>part[0])
  .join('')
  .toLocaleUpperCase(locale==='tr'?'tr-TR':'en-US');
---
<BaseLayout title={title} description={desc} locale={locale}>
  <PageHero eyebrow="SASTEK / CONTACT" title={title} text={desc} />

  <section class="section contact-section">
    <div class="container contact-layout">
      <aside class="identity-card glass">
        <div class="identity-top">
          <img class="estu-logo" src="/images/logo/estu-logo.png" alt={locale==='tr'?'Eskişehir Teknik Üniversitesi':'Eskişehir Technical University'} width="150" height="150" />
          <div>
            <p class="eyebrow">{locale==='tr'?'Üniversite Kulübü':'University Club'}</p>
            <h2>{locale==='tr'?'Eskişehir Teknik Üniversitesi':'Eskişehir Technical University'}</h2>
            <p>{locale==='tr'?'Savunma Sanayii ve Teknolojileri Kulübü':'Defence Industry and Technologies Club'}</p>
          </div>
        </div>

        <div class="follow-box">
          <span>{locale==='tr'?'Bizi takip edin':'Follow us'}</span>
          {activeSocials.length ? (
            <div class="social-links">
              {activeSocials.map((social)=>(
                <a href={social.url} target="_blank" rel="noreferrer" aria-label={`${social.label} ${locale==='tr'?'sayfasını yeni sekmede aç':'opens in a new tab'}`}>
                  <SocialIcon icon={social.icon} />
                  <span>{social.icon==='x'?'Twitter/X':social.label}</span>
                </a>
              ))}
            </div>
          ) : (
            <p class="muted">{locale==='tr'?'Sosyal medya bağlantıları güncellenecek.':'Social media links will be updated.'}</p>
          )}
        </div>
      </aside>

      <div class="board-panel">
        <div class="board-heading">
          <p class="eyebrow">{locale==='tr'?'Yönetim İletişimi':'Board Contact'}</p>
          <h2>{locale==='tr'?'Yönetim Ekibi':'Club board'}</h2>
        </div>

        <div class="board-cards" aria-label={locale==='tr'?'Yönetim Ekibi':'Club board'}>
          {activeTeam.map((person)=>(
            <article class="board-card glass">
              <div class:list={['avatar', person.photo && 'has-photo']} aria-hidden="true">
                {person.photo ? <img src={person.photo} alt="" width="96" height="96" loading="lazy" /> : initials(person.name)}
              </div>
              <div class="person-info">
                <span>{person.role[locale]}</span>
                <h3>{person.name}</h3>
                <div class="person-actions">
                  {person.email ? <a href={`mailto:${person.email}`}>{person.email}</a> : <p>{locale==='tr'?'E-posta güncellenecek':'Email to be updated'}</p>}
                  {person.linkedinUrl && <a class="linkedin-link" href={person.linkedinUrl} target="_blank" rel="noreferrer">LinkedIn</a>}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-section{padding-top:clamp(2rem,5vw,4rem)}
  .contact-layout{display:grid;grid-template-columns:minmax(280px,.78fr) minmax(0,1.22fr);gap:1.4rem;align-items:stretch}
  .identity-card{position:relative;display:flex;flex-direction:column;justify-content:space-between;overflow:hidden;border-radius:1.35rem;padding:clamp(1.6rem,3.5vw,2.4rem)}
  .identity-card::after{content:"";position:absolute;right:-28%;top:-20%;width:320px;aspect-ratio:1;border-radius:50%;background:radial-gradient(circle,rgba(255,107,26,.14),transparent 62%);pointer-events:none}
  .identity-top{position:relative;z-index:1;display:grid;justify-items:start;gap:1.35rem}
  .estu-logo{justify-self:center;width:10.2rem;height:10.2rem;object-fit:contain;filter:brightness(0) invert(1);opacity:.96}
  .identity-top h2{max-width:360px;margin:.4rem 0 .3rem;color:#fff;font-size:clamp(1.45rem,2.8vw,2.2rem);line-height:1.08}
  .identity-top p:not(.eyebrow){max-width:360px;margin:0;color:#a9bbce}
  .follow-box{position:relative;z-index:1;margin-top:clamp(1.6rem,5vw,3.5rem)}
  .follow-box>span{display:block;margin-bottom:.85rem;color:#fff;font-weight:900}
  .social-links{display:flex;flex-wrap:wrap;gap:.7rem}
  .social-links a{display:inline-flex;align-items:center;gap:.5rem;min-height:2.75rem;border:1px solid rgba(84,119,151,.42);border-radius:999px;background:rgba(5,14,25,.42);padding:.55rem .9rem;color:#fff;font-weight:850;transition:border-color .2s,background .2s,transform .2s}
  .social-links a:hover{border-color:rgba(255,107,26,.65);background:rgba(255,107,26,.1);transform:translateY(-2px)}
  .social-links :global(.social-icon){width:1rem;height:1rem;fill:currentColor}
  .board-panel{display:grid;grid-template-rows:auto 1fr;gap:1rem;min-width:0}
  .board-heading{display:flex;align-items:end;justify-content:space-between;gap:1rem;width:100%;padding:.35rem 0}
  .board-heading h2{margin:0;color:#fff;font-size:clamp(1.55rem,3vw,2.35rem);line-height:1.05}
  .board-heading .eyebrow{margin:0}
  .board-cards{display:grid;grid-template-rows:repeat(3,1fr);gap:1rem;width:100%;height:100%}
  .board-card{display:grid;grid-template-columns:5.15rem minmax(0,1fr);gap:1.05rem;align-items:center;width:100%;min-width:0;border-color:rgba(130,164,196,.2);border-radius:1.15rem;padding:1rem 1.05rem;transition:border-color .2s,transform .2s,background .2s}
  .board-card:hover{border-color:rgba(255,107,26,.35);background:linear-gradient(145deg,rgba(16,43,70,.86),rgba(7,21,38,.76));transform:translateY(-2px)}
  .avatar{display:grid;place-items:center;width:5.15rem;height:5.15rem;overflow:hidden;border:1px solid rgba(128,174,213,.28);border-radius:1.05rem;background:linear-gradient(145deg,rgba(255,107,26,.12),rgba(128,174,213,.1));color:#fff;font-size:1.45rem;font-weight:950;letter-spacing:.04em}
  .avatar.has-photo{border-color:rgba(128,174,213,.32);background:#071526}
  .avatar img{width:100%;height:100%;object-fit:cover}
  .person-info span{display:inline-flex;margin-bottom:.35rem;border:1px solid rgba(128,174,213,.22);border-radius:999px;padding:.18rem .55rem;color:#bad0e4;font-size:.72rem;font-weight:850}
  .person-info h3{margin:0;color:#fff;font-size:clamp(1.15rem,2vw,1.55rem);line-height:1.1}
  .person-actions{display:flex;align-items:center;gap:.55rem;flex-wrap:wrap;margin-top:.35rem}
  .person-actions a,.person-actions p{display:inline-flex;margin:0;color:#ff9a62;font-size:.95rem}
  .person-actions a:hover{color:#fff}
  .linkedin-link{border:1px solid rgba(128,174,213,.24);border-radius:999px;padding:.12rem .55rem;color:#bad0e4!important;font-size:.78rem!important;font-weight:850}
  .linkedin-link:hover{border-color:rgba(255,107,26,.45);color:#fff!important}
  @media(max-width:860px){.contact-layout{grid-template-columns:1fr}.board-panel{grid-template-rows:auto}.board-cards{grid-template-rows:none;height:auto}.board-heading{align-items:flex-start;flex-direction:column}.follow-box{margin-top:2rem}}
  @media(max-width:520px){.identity-card{padding:1.2rem}.estu-logo{width:7.6rem;height:7.6rem}.social-links{display:grid;grid-template-columns:1fr 1fr}.social-links a{justify-content:center}.board-card{grid-template-columns:1fr}.avatar{width:4.5rem;height:4.5rem}.person-actions a,.person-actions p{font-size:.88rem;word-break:break-word}}
</style>
